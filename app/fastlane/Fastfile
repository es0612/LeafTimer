update_fastlane

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"

  lane :unittests do
  scan(
    device: "iPhone 17",
    clean: true,
    scheme: "LeafTimer"
  )
  end

  # DEPRECATED: TestFlight 配信は Xcode Cloud Workflow に移行済み (Issue #13)。
  # この lane は緊急時 rollback 用に残してある。通常は git push で
  # Xcode Cloud が自動配信する。詳細: docs/ver1_2/xcode-cloud-setup.md
  lane :beta do
    unittests

    increment_build_number
    commit_version_bump(xcodeproj: "LeafTimer.xcodeproj")
    push_to_git_remote

    build_app(workspace: "LeafTimer.xcworkspace", scheme: "LeafTimer Release")
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end
end